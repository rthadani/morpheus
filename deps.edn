{:paths ["src" "resources"]

 :deps
 {org.clojure/clojure        {:mvn/version "1.12.0"}
  org.clojure/core.async     {:mvn/version "1.7.701"}

  ;; web
  http-kit/http-kit          {:mvn/version "2.8.0"}
  ring/ring-core             {:mvn/version "1.12.0"}
  ring/ring-defaults         {:mvn/version "0.5.0"}
  metosin/reitit-core        {:mvn/version "0.7.2"}
  metosin/reitit-ring        {:mvn/version "0.7.2"}
  hiccup/hiccup              {:mvn/version "2.0.0-RC3"}

  ;; system
  integrant/integrant        {:mvn/version "0.13.0"}

  ;; LLM
  com.walmartlabs/lacinia    {:mvn/version "1.2.2"}

  ;; util
  org.clojure/data.json      {:mvn/version "2.5.0"}
  aero/aero                  {:mvn/version "1.1.6"}
  com.taoensso/timbre        {:mvn/version "6.6.1"}}

 :aliases
 {:dev
  {:extra-paths ["test"]
   :extra-deps  {nrepl/nrepl              {:mvn/version "1.3.0"}
                 cider/cider-nrepl        {:mvn/version "0.50.2"}
                 nubank/matcher-combinators {:mvn/version "3.9.1"}}}

  :test
  {:extra-paths ["test"]
   :extra-deps  {io.github.cognitect-labs/test-runner
                 {:git/tag "v0.5.1" :git/sha "dfb30dd"}}}

  :nrepl
  {:main-opts ["-m" "nrepl.cmdline"
               "--middleware" "[cider.nrepl/cider-middleware]"
               "--port" "7888"]}

  :run
  {:main-opts ["-m" "morpheus.main"]}}}
